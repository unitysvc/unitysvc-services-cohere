const UNITYSVC_API_KEY = process.env.UNITYSVC_API_KEY;
const ENDPOINT = "https://api.cohere.ai/v1/vision";
const MODEL = "{{ routing_key.model }}";

// SINGLE-LINE 256×256 PNG BASE64
const imageB64 = "";

async function main() {
  const body = {
    model: MODEL,
    messages: [
      {
        role: "user",
        content: [
          { type: "text", text: "Describe this image." },
          {
            type: "image_url",
            image_url: { url: `data:image/png;base64,${imageB64}` }
          }
        ]
      }
    ]
  };

  const res = await fetch(ENDPOINT, {
    method: "POST",
    headers: {
      "Authorization": `Bearer ${UNITYSVC_API_KEY}`,
      "Content-Type": "application/json"
    },
    body: JSON.stringify(body)
  });

  const data = await res.json();
  console.log(data);
}

main();
